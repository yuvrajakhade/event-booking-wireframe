{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "esnext"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "allowJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vite/client", "react"]
  },
  "include": [
    "web-src/**/*",
    "src/data/mock.ts",
    "src/types.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
